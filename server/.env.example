# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/beast-cricket-auction
# Production: mongodb+srv://user:pass@cluster.mongodb.net/beast-cricket

# ─── JWT Secrets (CHANGE BOTH IN PRODUCTION) ──────────────────
JWT_SECRET=BeastCricket_AccessSecret_ChangeMe_2026
JWT_REFRESH_SECRET=BeastCricket_RefreshSecret_ChangeMe_2026

# ─── Frontend URL ─────────────────────────────────────────────
# Used by the email utility to build verification/reset links
FRONTEND_URL=http://localhost:3000
# Production: https://bca-frontend-production.up.railway.app

# ─── Email (Gmail SMTP) ───────────────────────────────────────
# Gmail App Password — requires 2FA enabled on the Gmail account
# IMPORTANT: Gmail App Password includes spaces (e.g., "gdgz afbz oyjm grxx")
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=beastcricketofficialauction@gmail.com
EMAIL_PASS=gdgz afbz oyjm grxx
EMAIL_FROM=Beast Cricket Auction <beastcricketofficialauction@gmail.com>

# ─── Cloudinary (optional — for permanent image storage) ──────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ─── Admin (single admin only) ───────────────────────────────
# Only this email can log in as admin — cannot be changed via UI
ADMIN_EMAIL=hirishi2020@gmail.com

# ─── Razorpay (free setup, pay per transaction) ───────────────
# Sign up at razorpay.com → Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Better Auth (optional — adds Google OAuth) ───────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=generate_a_32_plus_char_random_secret_here
BETTER_AUTH_URL=http://localhost:5000

# ─── Google OAuth (optional — for Google sign-in) ────────────
# Get from console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
-e 
# ─── Auction Creation Fee (paise, ₹499 = 49900) ────────────
AUCTION_CREATION_FEE_PAISE=49900
